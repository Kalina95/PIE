<span class="badge @GetCssClass(Priority)">@GetLabel(Priority)</span>

@code {
    [Parameter] public string Priority { get; set; } = "Medium";

    private static string GetLabel(string p) => p switch
    {
        "Low" => "Niski",
        "Medium" => "Średni",
        "High" => "Wysoki",
        "Critical" => "Krytyczny",
        _ => p
    };

    private static string GetCssClass(string p) => p switch
    {
        "Low" => "bg-info",
        "Medium" => "bg-secondary",
        "High" => "bg-warning text-dark",
        "Critical" => "bg-danger",
        _ => "bg-light text-dark"
    };
}
